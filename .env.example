# =============================================================================
# Tunas Workflow — Environment Variables
# Copy to .env and adjust values for local development.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=Tunas Workflow
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=3000
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://tunas:tunas_secret@localhost:5436/tunas_workflow?schema=public

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://tunas:tunas_secret@localhost:5672

# -----------------------------------------------------------------------------
# MinIO (Object Storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=tunas
MINIO_SECRET_KEY=tunas_secret
MINIO_BUCKET=tunas-attachments
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# AI Assistant (optional — works without key in Smart Analytics mode)
# -----------------------------------------------------------------------------
AI_ENABLED=true
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# JWT / Auth (placeholder — implement in auth module)
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Integration Worker & MQTT (Phase 6)
# -----------------------------------------------------------------------------
INTEGRATION_WORKER_ENABLED=true
INTEGRATION_WORKER_INTERVAL_MS=120000
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PATTERN=tunas/+/iot/alert
MQTT_TOPIC_PATTERNS=tunas/+/+/+/telemetry,tunas/+/+/telemetry,tunas/+/iot/alert,tunas/+/+/+/iot/alert

# -----------------------------------------------------------------------------
# Deployment / Multi-region (Phase 8)
# -----------------------------------------------------------------------------
DEPLOYMENT_REGION=default

# -----------------------------------------------------------------------------
# Web Frontend
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000/api

# -----------------------------------------------------------------------------
# Mobile (React Native — future)
# -----------------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
