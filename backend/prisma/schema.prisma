generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// TENANT
//////////////////////////////////////////////////////

model Tenant {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  domains      DomainNode[]
  users        User[]
  roles        Role[]
  apps         AppMaster[]
  appMenus     AppMenu[]
  transactions TransactionHeader[]
}

//////////////////////////////////////////////////////
// DOMAIN HIERARCHY
//////////////////////////////////////////////////////

model DomainNode {
  id         String   @id @default(uuid())
  tenantId   String
  parentId   String?
  domainCode String
  name       String
  type       String // LOCATION | ZONE | DEPARTMENT
  latitude   Float?
  longitude  Float?
  createdAt  DateTime @default(now())

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   DomainNode?  @relation("DomainHierarchy", fields: [parentId], references: [id])
  children DomainNode[] @relation("DomainHierarchy")

  @@unique([tenantId, domainCode])
  @@index([tenantId])
}

//////////////////////////////////////////////////////
// ROLE
//////////////////////////////////////////////////////

model Role {
  id          String  @id @default(uuid())
  tenantId    String
  name        String
  code        String
  permissions Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(uuid())
  tenantId  String
  username  String
  password  String?
  fullName  String
  email     String?
  roleId    String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role?  @relation(fields: [roleId], references: [id])
  llmConfig UserLlmConfig?

  @@unique([tenantId, username])
  @@index([tenantId])
}

//////////////////////////////////////////////////////
// USER LLM CONFIG (per-user ChatGPT / Gemini)
//////////////////////////////////////////////////////

model UserLlmConfig {
  id        String   @id @default(uuid())
  userId    String   @unique
  tenantId  String
  provider  String   // OPENAI | GEMINI
  apiKeyEnc String
  model     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

//////////////////////////////////////////////////////
// APPLICATION CONFIGURATION
//////////////////////////////////////////////////////

model AppMaster {
  id        String  @id @default(uuid())
  tenantId  String
  appCode   String
  name      String
  icon      String?
  dashboard String?
  active    Boolean @default(true)

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  process AppProcess[]
  routing AppRouting[]

  @@unique([tenantId, appCode])
  @@index([tenantId])
}

//////////////////////////////////////////////////////
// PROCESS CONFIG
//////////////////////////////////////////////////////

model AppProcess {
  id          String  @id @default(uuid())
  appId       String
  processCode String
  name        String
  sequence    Int
  isFinal     Boolean @default(false)

  app AppMaster @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([appId, processCode])
  @@index([appId])
}

//////////////////////////////////////////////////////
// ROUTING CONFIG
//////////////////////////////////////////////////////

model AppRouting {
  id          String  @id @default(uuid())
  appId       String
  fromProcess String
  toProcess   String
  condition   Json?
  roleCode    String?
  assignRule  Json?

  app AppMaster @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
}

//////////////////////////////////////////////////////
// APP MENU CONFIG
//////////////////////////////////////////////////////

model AppMenu {
  id         String  @id @default(uuid())
  tenantId   String
  appCode    String // SYSTEM | IT_SUPPORT | ISP_TICKET | ...
  menuCode   String
  label      String
  path       String
  icon       String?
  sequence   Int     @default(0)
  visible    Boolean @default(true)
  showWeb    Boolean @default(true)
  showMobile Boolean @default(false)
  roleCode   String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appCode, menuCode])
  @@index([tenantId, sequence])
}

//////////////////////////////////////////////////////
// TRANSACTION HEADER
//////////////////////////////////////////////////////

model TransactionHeader {
  id             String    @id @default(uuid())
  tenantId       String
  trxNo          String
  appCode        String
  domainCode     String?
  currentProcess String
  priority       String?
  status         String
  requestBy      String?
  assignTo       String?
  slaStatus      String?
  createdAt      DateTime  @default(now())
  closedAt       DateTime?

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  details TransactionDetail[]
  logs    TransactionLog[]
  assets  TransactionAsset[]

  @@index([tenantId, appCode])
  @@index([tenantId, domainCode])
}

//////////////////////////////////////////////////////
// TRANSACTION DETAIL
//////////////////////////////////////////////////////

model TransactionDetail {
  id            String @id @default(uuid())
  transactionId String
  fieldCode     String
  value         Json

  transaction TransactionHeader @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

//////////////////////////////////////////////////////
// TRANSACTION LOG
//////////////////////////////////////////////////////

model TransactionLog {
  id            String   @id @default(uuid())
  transactionId String
  process       String
  userId        String?
  action        String
  description   String?
  attachments   Json?
  metadata      Json?
  createdAt     DateTime @default(now())

  transaction TransactionHeader @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

//////////////////////////////////////////////////////
// ASSET
//////////////////////////////////////////////////////

model Asset {
  id           String   @id @default(uuid())
  tenantId     String
  assetCode    String
  name         String
  category     String // FIXED_ASSET | SPAREPART | TOOL
  serialNo     String?
  locationCode String?
  status       String
  metadata     Json?
  createdAt    DateTime @default(now())

  transactionLinks TransactionAsset[]

  pmSchedules PmSchedule[]

  @@unique([tenantId, assetCode])
  @@index([tenantId])
}

//////////////////////////////////////////////////////
// TRANSACTION ASSET LINK
//////////////////////////////////////////////////////

model TransactionAsset {
  id            String @id @default(uuid())
  transactionId String
  assetId       String
  usageType     String // AFFECTED | SPAREPART | TOOL
  qty           Float?

  transaction TransactionHeader @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  asset       Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([transactionId])
}

//////////////////////////////////////////////////////
// CONNECTOR
//////////////////////////////////////////////////////

model Connector {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  type     String // ODOO | GOOGLE | ISP | IOT | CUSTOM_API
  config   Json
  mapping  Json?
  active   Boolean @default(true)

  @@index([tenantId])
}

//////////////////////////////////////////////////////
// EVENT QUEUE
//////////////////////////////////////////////////////

model EventQueue {
  id        String   @id @default(uuid())
  tenantId  String
  source    String
  eventType String
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, processed])
}

//////////////////////////////////////////////////////
// IN-APP NOTIFICATION
//////////////////////////////////////////////////////

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  title     String
  message   String
  type      String
  refType   String?
  refId     String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tenantId, userId, read])
  @@index([tenantId, userId, createdAt])
}

//////////////////////////////////////////////////////
// PM SCHEDULE (Preventive Maintenance)
//////////////////////////////////////////////////////

model PmSchedule {
  id          String    @id @default(uuid())
  tenantId    String
  title       String
  description String?
  assetId     String?
  domainCode  String?
  frequency   String // WEEKLY | MONTHLY | QUARTERLY
  nextRunAt   DateTime
  lastRunAt   DateTime?
  assignTo    String?
  checklist   Json
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  asset Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([tenantId, active, nextRunAt])
}
